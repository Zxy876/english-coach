// english-coach — Prisma schema
// Inherited from maieutic; SQLite for MVP, Postgres swap is mechanical.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Exercise {
  id                   String   @id // slug
  title                String
  instructorPromptText String
  authoredAt           DateTime @default(now())
  publishedAt          DateTime?
  targetLanguage       String   @default("python") // "python" | "java" | "math-symbolic" | "math-geometric" | "math-proof" | "math-formal" | "math-theoretical"

  // Final, post-edit
  specGateDimensions   Json     // SpecDimension[]
  expectedDivergences  Json     // ExpectedDivergence[]
  studentLevel         String   // "week_1_2" | "week_3_6" | "week_7_plus"
  unit                 String   @default("unit_2") // "unit_1" | "unit_2" | "unit_3" | "unit_4"

  // Authoring trace — Opus first-pass output, preserved
  opusGeneratedDimensions      Json
  opusGeneratedDivergences     Json
  opusGeneratedStudentLevel    String

  // Math-specific fields
  mathProblemType      String?  // "calculable" | "geometric" | "proof" | "theoretical" | "advanced" | "mixed"
  allowedModes         Json?    // String[] - 允许的表示模式
  mathFramework        String?  // 数学框架（如 "ZFC", "metric_space", "topological_space"）
  requiredTheorems     Json?    // String[] - 需要的定理
  requiredDefinitions  Json?    // String[] - 需要的定义

  sessions             Session[]
  translations         ExerciseTranslation[]
}

// Per-language cache of an Exercise's student-visible text. Populated on
// demand the first time a student in that language loads the exercise,
// then read from cache for every subsequent request. Invalidate by
// deleting rows (no sourceHash: exercise content changes should be
// accompanied by a manual re-translation since instructors author in
// English).
model ExerciseTranslation {
  exerciseId           String
  lang                 String   // "en" | "es"
  title                String
  instructorPromptText String
  createdAt            DateTime @default(now())

  exercise             Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@id([exerciseId, lang])
}

model Session {
  id            String   @id @default(cuid())
  studentId     String   // free-form string for MVP; no auth
  exerciseId    String
  exercise      Exercise @relation(fields: [exerciseId], references: [id])
  startedAt     DateTime @default(now())
  lastActiveAt  DateTime @default(now())
  completedAt   DateTime?
  currentPhase  Int      // 1 (spec), 2 (writing), 3 (review), or 4 (closed)

  phase1Data    Json     // Phase1Data
  phase2Data    Json     // Phase2Data (starts empty)
  phase3Data    Json?    // Phase3Data
  liveSummaries Json     // LiveSummary[] (append-only)

  events        SessionEvent[]

  @@index([exerciseId])
  @@index([completedAt])
  @@index([lastActiveAt])
}

model SessionEvent {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id])
  kind      String   // "phase_transition" | "alignment_failure" | "help_request" | "revision" | "summary_refresh"
  payload   Json
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([sessionId, createdAt])
}

// ─── NCE (New Concept English) content layer ──────────────────────────────
// Mirrors the data hosted at https://nce.mleo.site/<bookKey>/. One row per
// book / per lesson / per timestamped sentence. The remix surfaces (R3+)
// reference these rows by id; audio assets stay on the upstream CDN until
// R2.5's mirror script runs (then `audioUrl` flips to a local path).

model NceBook {
  key       String   @id      // "NCE1" | "NCE2" | "NCE3" | "NCE4" | "NCE1(85)" | ...
  title     String
  bookPath  String            // upstream CDN root, e.g. "https://nce.mleo.site/NCE1"
  bookLevel String?           // from book.json
  bookCover String?           // relative path under bookPath
  fetchedAt DateTime @default(now())

  lessons   NceLesson[]
}

model NceLesson {
  id        String   @id @default(cuid())
  bookKey   String
  book      NceBook  @relation(fields: [bookKey], references: [key], onDelete: Cascade)
  ordinal   Int      // 1-based position within the book (matches upstream `units[]` order)
  title     String
  filename  String   // upstream basename, e.g. "L001" — combine with bookPath for mp3/lrc URLs
  audioUrl  String
  lrcUrl    String
  fetchedAt DateTime @default(now())

  sentences NceSentence[]

  @@unique([bookKey, ordinal])
  @@index([bookKey])
}

model NceSentence {
  id        String   @id @default(cuid())
  lessonId  String
  lesson    NceLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  ordinal   Int      // 1-based, ordered by `startMs`
  startMs   Int      // start time in ms (already de-offset by the -0.5s the upstream player applies)
  english   String
  chinese   String   // may be empty if upstream LRC has no translation column

  @@unique([lessonId, ordinal])
  @@index([lessonId])
}
